# =====================================================================
# Ram Pottery Hub — environment example
# Copy this file to ".env" and fill in your real values.
# NEVER commit a real .env (it contains the Supabase service role key).
# =====================================================================

# ---- Supabase (client) ----
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_SUPABASE_PROJECT_ID=your-project-id

# ---- Supabase (server only — keep secret, never exposed to the browser, never commit the real value) ----
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Express API ----
# Port the Express API listens on. The Vite dev proxy reads this automatically.
API_PORT=3001

# ---- Dev API proxy target (optional override) ----
# If set, the Vite dev server proxies /api/* to this exact URL.
# Otherwise it uses http://localhost:${API_PORT}, falling back to :3001.
# VITE_API_TARGET=http://localhost:3010

# ---- Browser dev override (optional) ----
# In the browser, API calls normally go same-origin to /api/* (Vite proxy in dev,
# same host in prod). Set this only if you need the browser to call an API on a
# different origin during local dev.
# VITE_API_URL=http://localhost:3001

# ---- Misc ----
VITE_PUBLIC_SITE_URL=https://rampotteryhub.com
VERCEL_PDF_ORIGIN=
